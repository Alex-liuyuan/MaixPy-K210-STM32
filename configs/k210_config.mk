# K210平台配置
CONFIG_PLATFORM=k210
CONFIG_PLATFORM_K210=y

# 编译器配置
CONFIG_TOOLCHAIN_PREFIX=riscv64-unknown-elf-
CONFIG_CC=riscv64-unknown-elf-gcc
CONFIG_CXX=riscv64-unknown-elf-g++
CONFIG_AR=riscv64-unknown-elf-ar
CONFIG_OBJCOPY=riscv64-unknown-elf-objcopy
CONFIG_OBJDUMP=riscv64-unknown-elf-objdump

# CPU配置
CONFIG_CPU_FREQ=400000000
CONFIG_CPU_ARCH=riscv64
CONFIG_CPU_CORES=2

# 内存配置
CONFIG_MEMORY_SIZE=6291456
CONFIG_HEAP_SIZE=2097152
CONFIG_STACK_SIZE=65536

# 外设配置
CONFIG_GPIO_SUPPORT=y
CONFIG_SPI_SUPPORT=y
CONFIG_I2C_SUPPORT=y
CONFIG_UART_SUPPORT=y
CONFIG_PWM_SUPPORT=y

# 摄像头配置
CONFIG_CAMERA_SUPPORT=y
CONFIG_CAMERA_DVP=y
CONFIG_CAMERA_OV2640=y
CONFIG_CAMERA_OV5640=y

# 显示配置
CONFIG_DISPLAY_SUPPORT=y
CONFIG_DISPLAY_ST7789=y
CONFIG_DISPLAY_ILI9341=y

# AI加速器配置
CONFIG_KPU_SUPPORT=y
CONFIG_KPU_V1=y

# 文件系统配置
CONFIG_FILESYSTEM_SUPPORT=y
CONFIG_FATFS=y
CONFIG_SPIFFS=y

# 网络配置
CONFIG_NETWORK_SUPPORT=n
CONFIG_WIFI_SUPPORT=n

# 音频配置
CONFIG_AUDIO_SUPPORT=y
CONFIG_I2S_SUPPORT=y

# 调试配置
CONFIG_DEBUG=y
CONFIG_LOG_LEVEL=3

# Python配置
CONFIG_PYTHON_SUPPORT=y
CONFIG_PYTHON_VERSION=3.8

# 构建配置
CONFIG_BINARY_NAME=maixpy_k210
CONFIG_OUTPUT_DIR=build/k210