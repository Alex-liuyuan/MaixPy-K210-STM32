	$(MAKE) $(MAKESILENT) -f CMakeFiles/MaixPy_sim.dir/build.make CMakeFiles/MaixPy_sim.dir/sim_syscalls.c.i
.PHONY : sim_syscalls.c.i

sim_syscalls.s: sim_syscalls.c.s
.PHONY : sim_syscalls.s

