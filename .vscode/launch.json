{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "QEMU: Debug RT-Thread (STM32F407)",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "qemu",
      "serverpath": "qemu-system-arm",
      "qemuArgs": [
        "-machine", "olimex-stm32-h405",
        "-nographic",
        "-semihosting",
        "-kernel", "${workspaceFolder}/build/sim/MaixPy_sim.elf",
        "-no-reboot",
        "-S",
        "-gdb", "tcp::3333"
      ],
      "gdbPath": "gdb-multiarch",
      "executable": "${workspaceFolder}/build/sim/MaixPy_sim.elf",
      "device": "STM32F407VG",
      "runToEntryPoint": "main",
      "showDevDebugOutput": "none",
      "preLaunchTask": "Build Sim Firmware"
    },
    {
      "name": "QEMU: Attach GDB (already running)",
      "type": "cortex-debug",
      "request": "attach",
      "servertype": "external",
      "gdbTarget": "localhost:3333",
      "gdbPath": "gdb-multiarch",
      "executable": "${workspaceFolder}/build/sim/MaixPy_sim.elf",
      "device": "STM32F407VG",
      "showDevDebugOutput": "none"
    }
  ]
}
